# Optional LLM configuration
# Leave OPENAI_API_KEY empty to run with the deterministic MockProvider.
OPENAI_API_KEY=
LLM_PROVIDER=auto
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# Retrieval backend
# Use memory for the most reproducible local/CI mode.
# Use chroma to persist vectors and chunk metadata under CHROMA_PERSIST_DIRECTORY.
VECTOR_STORE=memory
CHROMA_PERSIST_DIRECTORY=data/vector_store
CHROMA_COLLECTION_NAME=enterprise_document_chunks

# Optional CrossEncoder reranking
# Keep disabled by default because the first enabled run may download the model.
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=20
RERANKER_FINAL_K=5

# Debugging
# Set to 1 to show full Streamlit tracebacks.
APP_DEBUG=0
